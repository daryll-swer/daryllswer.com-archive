{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daryllswer.com/schemas/spreadsheet-manifest.schema.json",
  "type": "object",
  "required": ["generated_at", "source_url", "title", "ods", "tabs"],
  "properties": {
    "generated_at": {"type": "string"},
    "source_url": {"type": "string"},
    "title": {"type": "string"},
    "ods": {"type": "object"},
    "workbook_html": {"type": "object"},
    "published_workbook_html": {"type": "object"},
    "cidr_hierarchy": {"type": "object"},
    "visual_options": {"type": "object"},
    "tabs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gid", "name", "csv", "html"],
        "properties": {
          "gid": {"type": "string"},
          "name": {"type": "string"},
          "csv": {"type": "object"},
          "html": {"type": "object"},
          "csvw": {"type": "object"}
        }
      }
    }
  }
}
